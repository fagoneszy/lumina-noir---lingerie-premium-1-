{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public user profile data.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "description": "An item saved to a user's wishlist.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "addedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/users/{userId}/wishlist/{productId}": {
      "schema": "WishlistItem",
      "description": "Items in a user's wishlist"
    }
  }
}
